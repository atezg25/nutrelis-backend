# ============================================
# NUTRELIS BACKEND — Variables d'environnement
# ============================================

# Mode
NODE_ENV=production

# CORS — domaines autorisés (séparés par des virgules)
STORE_CORS=https://nutrelis-v76z.vercel.app
ADMIN_CORS=https://nutrelis-backend-production.up.railway.app
AUTH_CORS=https://nutrelis-v76z.vercel.app,https://nutrelis-backend-production.up.railway.app

# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (cache, events)
REDIS_URL=redis://default:password@host:6379

# Secrets (OBLIGATOIRES en production — générer avec: openssl rand -hex 32)
JWT_SECRET=
COOKIE_SECRET=

# ============================================
# STOCKAGE FICHIERS — Cloudflare R2 / AWS S3
# (optionnel — si non défini, utilise le stockage local)
# ============================================
# S3_FILE_URL=https://pub-xxx.r2.dev
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_BUCKET=nutrelis-media
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
